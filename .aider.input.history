# 2026-03-01 10:24:01.325078
+Harden MQTT TLS in waterfront-esp32 with client cert support and robust error handling.
+
+1. In config_loader.h: add String clientCertPath = ""; String clientKeyPath = "";
+
+2. In config_loader.cpp: parse "mqtt.clientCertPath" and "mqtt.clientKeyPath"
+
+3. In mqtt_client.cpp connect:
+   if (g_config.mqtt.useTLS) {
+     File ca = LittleFS.open(g_config.mqtt.caCertPath, "r");
+     if (!ca) {
+       ESP_LOGE("MQTT", "CA cert missing – aborting TLS");
+       return false;
+     }
+     mqttClient.setCACert(ca.readString().c_str());
+
+     if (g_config.mqtt.clientCertPath.length() > 0) {
+       File cert = LittleFS.open(g_config.mqtt.clientCertPath, "r");
+       File key = LittleFS.open(g_config.mqtt.clientKeyPath, "r");
+       if (cert && key) {
+         mqttClient.setCertificate(cert.readString().c_str(), key.readString().c_str());
+       } else {
+         ESP_LOGW("MQTT", "Client cert/key missing – continuing without");
+       }
+     }
+   }
+
+Show diffs for config_loader.h/cpp + mqtt_client.cpp.
+Commit: "security: full TLS with client cert + robust error handling"

