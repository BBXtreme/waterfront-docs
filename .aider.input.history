+Harden MQTT TLS in waterfront-esp32 with real CA cert validation.
+
+1. In config_loader.h: add String caCertPath = "/ca.pem"; to mqtt struct
+
+2. In config_loader.cpp loadConfig(): parse "mqtt.caCertPath" from JSON (default "/ca.pem")
+
+3. In mqtt_client.cpp connect logic:
+   if (g_config.mqtt.useTLS) {
+     File caFile = LittleFS.open(g_config.mqtt.caCertPath, "r");
+     if (caFile) {
+       String ca = caFile.readString();
+       mqttClient.setCACert(ca.c_str());
+       mqttClient.setSecure(true);
+       ESP_LOGI("MQTT", "Loaded CA cert from %s", g_config.mqtt.caCertPath.c_str());
+     } else {
+       ESP_LOGE("MQTT", "CA cert missing – using insecure TLS");
+       mqttClient.setSecure(true);  // fallback without verification
+     }
+   }
+
+4. Update default config.json: add "caCertPath": "/ca.pem", "useTLS": true, "port": 8883
+
+5. Add comment: "Place ca.pem in data/ folder before first uploadfs. Use public root cert for production broker."
+
